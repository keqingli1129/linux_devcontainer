// Variant of ../devcontainer.json for a native Linux host reached over plain SSH
// (no WSL2/Docker Desktop, no WSLg). Reuses the same Dockerfile.
{
	"name": "C++ (Linux/SSH)",
	"build": {
		"dockerfile": "../Dockerfile",
		"context": ".."
	},

	"runArgs": [
		"--gpus=all",
		"--device=/dev/video0:/dev/video0",
		"--group-add=video",
		// VS Code Remote-SSH's own X11 forwarding binds a TCP listener to
		// 127.0.0.1 on the remote host (it does not create a
		// /tmp/.X11-unix socket). The container's default bridge network
		// has its own loopback, so that port is unreachable unless the
		// container shares the host's network namespace.
		"--network=host"
	],

	"hostRequirements": {
		"gpu": true
	},

	// sshd writes the X11 forwarding auth cookie into the SSH login user's
	// ~/.Xauthority on the host. --network=host gives the container
	// reachability to the forwarded TCP port, but not this file, so X
	// clients fail auth ("Can't open display") without it mounted in too.
	"mounts": [
		"source=${localEnv:HOME}/.Xauthority,target=/home/vscode/.Xauthority,type=bind"
	],

	"containerEnv": {
		"DISPLAY": "${localEnv:DISPLAY}",
		"XAUTHORITY": "/home/vscode/.Xauthority",
		"NVIDIA_DRIVER_CAPABILITIES": "all"
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools"
			]
		}
	}
}
