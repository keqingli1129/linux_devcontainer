// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
	"name": "C++",
	"build": {
		"dockerfile": "Dockerfile"
	},

	// Pass the WSL2-attached webcam through to the container.
	"runArgs": [
		"--device=/dev/video0:/dev/video0",
		"--device=/dev/video1:/dev/video1",
		"--group-add=video",
		"--gpus=all"
	],

	// Requests a GPU when the container is created (e.g. via Codespaces or devcontainer CLI).
	"hostRequirements": {
		"gpu": true
	},

	// WSLg puts its X11/Wayland sockets in the Ubuntu-24.04 WSL distro. VS Code runs on
	// the Windows host, so Docker Desktop resolves plain Linux paths (/mnt/wslg) inside
	// its own docker-desktop VM where they don't exist — reach the distro's files via the
	// \\wsl.localhost UNC path instead. Update the distro name here if it changes.
	"mounts": [
		"source=\\\\wsl.localhost\\Ubuntu-24.04\\mnt\\wslg\\.X11-unix,target=/tmp/.X11-unix,type=bind",
		"source=\\\\wsl.localhost\\Ubuntu-24.04\\mnt\\wslg,target=/mnt/wslg,type=bind"
	],

	// ${localEnv:...} resolves against the Windows environment (no DISPLAY etc. there),
	// so hard-code the values WSLg uses inside the distro.
	"containerEnv": {
		"DISPLAY": ":0",
		"WAYLAND_DISPLAY": "wayland-0",
		"XDG_RUNTIME_DIR": "/mnt/wslg/runtime-dir",
		"PULSE_SERVER": "/mnt/wslg/PulseServer"
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "gcc -v",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
