// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/cpp
{
	"name": "C++",
	"build": {
		"dockerfile": "Dockerfile"
	},

	// Pass the WSL2-attached webcam through to the container.
	"runArgs": [
		"--device=/dev/video0:/dev/video0",
		"--device=/dev/video1:/dev/video1",
		"--group-add=video",
		"--gpus=all",
		"-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw",
		"--net=host"
	],

	// Requests a GPU when the container is created (e.g. via Codespaces or devcontainer CLI).
	"hostRequirements": {
		"gpu": true
	},

	"containerEnv": {
		"DISPLAY": "${localEnv:DISPLAY}",
		"LIBGL_ALWAYS_SOFTWARE": "1",
		"XDG_RUNTIME_DIR": "/tmp/runtime-${localEnv:USER}"
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// On Windows, DISPLAY is empty — fall back to host.docker.internal:0
	"postStartCommand": "if [ -z \"$DISPLAY\" ]; then echo 'export DISPLAY=host.docker.internal:0' >> ~/.bashrc; fi",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools"
			]
		}
	},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
